# Copy to .env and adjust for your machine. justfile loads .env automatically.

# RetroArch app binary and core directory.
RETROARCH_BIN="/Applications/RetroArch.app/Contents/MacOS/RetroArch"
RETROARCH_CORES="$HOME/Library/Application Support/RetroArch/cores"

# Preferred N64 homebrew emulator for current libdragon ROMs.
ARES_BIN="/Applications/ares.app/Contents/MacOS/ares"

# SNES PVSnesLib checkout. On macOS, GNU sed is needed for PVSnesLib's Makefiles.
PVSNESLIB_HOME="$HOME/.cache/chipviz/pvsneslib"
GNU_SED_BIN="/opt/homebrew/opt/gnu-sed/libexec/gnubin"

# Optional native SDK paths. If unset, debug recipes use Docker where possible.
# DEVKITARM="/opt/devkitpro/devkitARM"
# N64_INST="$HOME/.local/share/libdragon"
